# ─── Backend ──────────────────────────────────────────────────────────
# All AMSG_* vars are read by app/core/config.py via pydantic-settings.

# Enable verbose logging and live reload behaviour.
AMSG_DEBUG=false

# CORS allow-list. JSON array. Use ["*"] for full permissiveness in dev.
# When using the bundled nginx (same-origin), CORS is irrelevant — leave it
# permissive only if the frontend is hosted somewhere else.
AMSG_CORS_ORIGINS=["http://localhost:5173"]

# Job manager.
AMSG_MAX_CONCURRENT_JOBS=2
AMSG_JOB_TTL_SECONDS=3600

# ─── Frontend ─────────────────────────────────────────────────────────
# Build-time only — baked into the Vite bundle. With docker compose,
# nginx proxies /api to the backend so leave this as /api.
VITE_API_BASE_URL=/api

# Host port the frontend container listens on. Container always exposes 80.
FRONTEND_PORT=5173
